{
  "$schema": "https://opencode.ai/config.json",
  "model": "gpt-5.2-codex",
  "mcp": {
    "Maestro": {
      "type": "local",
      "command": ["maestro", "mcp"],
      "enabled": false
    },
    "Mise": {
      "type": "local",
      "command": ["mise", "mcp"],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "ctx7sk-9fef4f1c-cee6-4f46-ad53-82ea6bd65d4c"
      ],
      "enabled": false
    },
    "Chrome": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "Bun": {
      "type": "remote",
      "url": "https://bun.com/docs/mcp",
      "enabled": false
    }
  }
}
