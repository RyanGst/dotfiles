[gpg]
	format = ssh
[user]
	signingkey = /Users/ryangst/.ssh/id_ed25519_sign.pub
	name = "Ryan Machado"
	email = "me@ryanmac.dev"
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[merge]
	tool = idea
[mergetool "idea"]
	cmd = idea merge "$LOCAL" "$REMOTE" "$BASE" "$MERGED"
[commit]
	gpgsign = true
[color]
	ui = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
	side-by-side = false
	line-numbers = true
	syntax-theme = tokyonight_night
[include]
	path = ~/.config/bat/themes/tokyonight.nvim/extras/delta/tokyonight_night.gitconfig
[url "ssh://git@github-work/"]
	insteadOf = https://github.com/
	insteadOf = git@github.com:
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[includeIf "hasconfig:remote.*.url:https://github.com/tigertext/**"]
	path = ~/.gitconfig-work
[includeIf "hasconfig:remote.*.url:git@github.com:tigertext/**"]
	path = ~/.gitconfig-work
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/tigertext/**"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/Developer/tc-rmachado/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/.claude/"]
	path = ~/.gitconfig-work
